<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Schedly - Login</title>
    <link rel="stylesheet" href="css/styles.css">
</head>

<body>
    
    <!-- Navigation Bar -->
    <nav>
        <a href="final_login_page.html" class="active">Login</a>
        <a href="index.html">Dashboard</a>
        <a href="final_addtask_page.html">Add Task</a>
        <a href="final_taskdetail_page.html">Task Detail</a>
    </nav>

    <div class="container">

        <!-- LEFT: Login Section -->
        <div class="login-section">

            <h1>Schedly</h1>

            <h2>Login</h2>

            <label>Username:</label>
            <input type="text" placeholder="Username">

            <label>Password:</label>
            <input type="password" placeholder="Password">

            <button>Log in</button>

            <p>
                <a href="#">Create account</a> |
                <a href="#">Forgot password</a>
            </p>

        </div>

        <!-- RIGHT: Sign Up Section -->
        <div class="signup-section">

            <h2>Sign in</h2>

            <label>Username:</label>
            <input type="text" placeholder="Username">

            <label>Email:</label>
            <input type="email" placeholder="Email">

            <label>Password:</label>
            <input type="password" placeholder="Password">

            <button>Create Account</button>

            <hr>

            <!-- Password Reset -->
            <h3>Password Reset</h3>

            <label>Email:</label>
            <input type="email" placeholder="Enter your email">

            <button>Email me verification code</button>

        </div>

    </div>

</body>

</html>
